HEART360TK_VERSION=0.5.0
POSTGRES_HOST=postgres
POSTGRES_DB=heart360tk_database
POSTGRES_USER=heart360tk
POSTGRES_PASSWORD=YmE4ZTk0OGI0OTNmNGU5YmFjZDY1YTA0

# -----------------------------------------------------------------------------
# IMPORTER
# -----------------------------------------------------------------------------
# IMPORT_CRON=5 * * * *
# IMPORT_PROTOCOL=sftp
# IMPORT_AGGREAGATE_DATA=true
# IMPORT_FOLDER_PATH=/upload

# -----------------------------------------------------------------------------
# SFTP server (leaf node's SFTP server creds — used by importer to pull data)
# -----------------------------------------------------------------------------
# SFTP_HOST=host.docker.internal
# SFTP_PORT=2222
# SFTP_USER=h360tk_sftp
# SFTP_PASSWORD=h360tk_pass
# SFTP_DEST_PATH=/upload
# SFTP_TIMEOUT=60


# -----------------------------------------------------------------------------
# S3 upload (set UPLOAD_PROTOCOL=s3 to enable)
# -----------------------------------------------------------------------------
# S3_BUCKET=your-bucket-name
# S3_KEY_PREFIX=uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT_URL=your-s3-endpoint-url            
