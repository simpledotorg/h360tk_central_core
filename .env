HEART360TK_VERSION=h360-149_aggregate_data_exporter.215
POSTGRES_HOST=postgres
POSTGRES_DB=heart360tk_database
is_central_node=false
SOURCE_KEY=h360tk_demo
EXPORT_CRON=0 * * * *
UPLOAD_PROTOCOL=file
UPLOAD_DEST_PATH=/export

# SFTPGo process uid:gid — must match the user:group that owns ./.upload on the host (see `id -u`, `id -g`).
HOST_UID=1000
HOST_GID=1000

# FTP passive mode: must match the host clients use in ftp://HOST:2121 (see docker-compose sftpgo).
FTP_PASSIVE_IP=127.0.0.1

# -----------------------------------------------------------------------------
# Exporter: S3 upload (set UPLOAD_PROTOCOL=s3 to enable)
# -----------------------------------------------------------------------------
# S3_BUCKET=your-bucket-name
# S3_KEY_PREFIX=uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT_URL=your-s3-endpoint-url            

# -----------------------------------------------------------------------------
# Exporter: SFTP upload (set UPLOAD_PROTOCOL=sftp to enable)
# -----------------------------------------------------------------------------
# SFTP_HOST=your-sftp-host
# SFTP_PORT=22
# SFTP_USER=your-sftp-user
# SFTP_PASSWORD=your-sftp-password
# SFTP_DEST_PATH=/upload
# SFTP_TIMEOUT=60